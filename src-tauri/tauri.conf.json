{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/packages/api/schema.json",
  "productName": "snipx",
  "version": "0.1.0",
  "identifier": "sh.snipx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run vite",
    "beforeBuildCommand": "bun run vite build"
  },
  "app": {
    "windows": [
      {
        "title": "SNIPX",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
